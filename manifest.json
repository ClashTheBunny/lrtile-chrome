{
  "manifest_version": 3,

  "name": "lrTile, Tiling Window mover for Chrome",
  "short_name": "lrtile",
  "description":
     "lrTile uses keyboard shortcuts and a popup menu to snap windows to halves, quarters, and more, Rectangle-style.",
  "version": "0.3",
  "icons": {"256": "lrtile.png"},

  "permissions": [
    "tabs",
    "storage",
    "system.display"
  ],

  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },

  "action": {
    "default_icon": "lrtile.png",
    "default_popup": "popup.html",
    "default_title": "lrTile"
  },

  "background" : {
    "service_worker": "lrtile.js"
  },

  "commands": {
    "01-lr-left-half": {
      "description": "Left Half",
      "suggested_key": { "default": "Ctrl+Shift+Left" }
    },
    "02-lr-right-half": {
      "description": "Right Half",
      "suggested_key": { "default": "Ctrl+Shift+Right" }
    },
    "03-lr-top-half": {
      "description": "Top Half"
    },
    "04-lr-bottom-half": {
      "description": "Bottom Half"
    },
    "05-lr-top-left": {
      "description": "Top Left Quarter"
    },
    "06-lr-top-right": {
      "description": "Top Right Quarter"
    },
    "07-lr-bottom-left": {
      "description": "Bottom Left Quarter"
    },
    "08-lr-bottom-right": {
      "description": "Bottom Right Quarter"
    },
    "09-lr-maximize": {
      "description": "Maximize",
      "suggested_key": { "default": "Alt+Shift+F" }
    },
    "10-lr-center": {
      "description": "Center",
      "suggested_key": { "default": "Alt+Shift+C" }
    }
  }
}


